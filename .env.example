# Django
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,0.0.0.0

# Veritabanı (PostgreSQL)
POSTGRES_NAME=manevi_rehber
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/manevi_rehber

# JWT Ayarları
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# External API'ler
ALADHAN_BASE_URL=https://api.aladhan.com/v1
QURAN_API_BASE_URL=https://quranenc.com/api/v1/translation/aya
QURAN_API_TRANSLATION=turkish_shaban
HADITH_API_BASE_URL=https://cdn.jsdelivr.net/gh/fawazahmed0/hadith-api@1
HADITH_DEFAULT_COLLECTION=tur-bukhari

# Redis (opsiyonel, cache için)
REDIS_URL=redis://localhost:6379/0

# CORS (React Native için)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Firebase (opsiyonel, push notification için)
FIREBASE_CREDENTIALS=
USE_FIREBASE=False
